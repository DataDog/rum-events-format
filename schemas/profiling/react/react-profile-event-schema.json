{
    "$schema": "http://json-schema.org/draft-07/schema",
    "$id": "profiling/react/react-profile-event-schema.json",
    "title": "ReactProfileEvent",
    "type": "object",
    "description": "Schema for a React profiling session event, covering a time window of batched component render samples.",
    "allOf": [
        {
            "$ref": "_common-schema.json"
        },
        {
            "required": [
                "start",
                "end",
                "attachments"
            ],
            "properties": {
                "start": {
                    "type": "string",
                    "description": "ISO 8601 timestamp of when the profiling window started.",
                    "readOnly": true
                },
                "end": {
                    "type": "string",
                    "description": "ISO 8601 timestamp of when the profiling window ended.",
                    "readOnly": true
                },
                "attachments": {
                    "type": "array",
                    "description": "List of profile attachment filenames.",
                    "items": {
                        "type": "string",
                        "enum": [
                            "react-profiling.json"
                        ]
                    },
                    "readOnly": true
                }
            }
        }
    ]
}