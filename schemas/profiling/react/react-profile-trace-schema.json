{
    "$schema": "http://json-schema.org/draft-07/schema",
    "$id": "profiling/react/react-profile-trace-schema.json",
    "title": "ReactProfileTrace",
    "type": "object",
    "description": "Trace attachment for a React profiling session. Contains render samples grouped by React commit batch.",
    "required": [
        "samples"
    ],
    "properties": {
        "samples": {
            "type": "array",
            "description": "Render samples, one per React commit batch.",
            "items": {
                "type": "object",
                "required": [
                    "timestamp",
                    "renders"
                ],
                "properties": {
                    "timestamp": {
                        "type": "string",
                        "description": "ISO 8601 timestamp of the earliest render in this batch.",
                        "readOnly": true
                    },
                    "renders": {
                        "type": "array",
                        "description": "Component renders that occurred in this commit batch.",
                        "items": {
                            "type": "object",
                            "required": [
                                "component",
                                "phase",
                                "duration"
                            ],
                            "properties": {
                                "component": {
                                    "type": "string",
                                    "description": "Name of the React component being profiled.",
                                    "readOnly": true
                                },
                                "phase": {
                                    "type": "string",
                                    "enum": [
                                        "mount",
                                        "update",
                                        "nested-update"
                                    ],
                                    "description": "React render phase.",
                                    "readOnly": true
                                },
                                "duration": {
                                    "type": "integer",
                                    "minimum": 0,
                                    "description": "Total render duration in nanoseconds, including all lifecycle phases.",
                                    "readOnly": true
                                },
                                "render_phase_duration": {
                                    "type": "integer",
                                    "minimum": 0,
                                    "description": "Time spent in the render phase in nanoseconds. Only present in standard mode.",
                                    "readOnly": true
                                },
                                "layout_effect_phase_duration": {
                                    "type": "integer",
                                    "minimum": 0,
                                    "description": "Time spent in useLayoutEffect in nanoseconds. Only present in standard mode.",
                                    "readOnly": true
                                },
                                "effect_phase_duration": {
                                    "type": "integer",
                                    "minimum": 0,
                                    "description": "Time spent in useEffect in nanoseconds. Only present in standard mode.",
                                    "readOnly": true
                                },
                                "base_duration": {
                                    "type": "integer",
                                    "minimum": 0,
                                    "description": "Estimated time to re-render the subtree from scratch in nanoseconds. Only present when using react-dom/profiling build.",
                                    "readOnly": true
                                }
                            }
                        },
                        "readOnly": true
                    }
                }
            },
            "readOnly": true
        }
    }
}