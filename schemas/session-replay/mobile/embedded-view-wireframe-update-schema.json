{
  "$schema": "http://json-schema.org/draft-07/schema",
  "$id": "session-replay/mobile/embedded-view-wireframe-update-schema.json",
  "title": "EmbeddedViewWireframeUpdate",
  "type": "object",
  "description": "Schema of all properties of an EmbeddedViewWireframeUpdate.",
  "allOf": [
    {
      "$ref": "_common-shape-wireframe-update-schema.json"
    },
    {
      "required": ["type", "slotId"],
      "properties": {
        "type": {
          "type": "string",
          "description": "The type of the wireframe.",
          "const": "embedded_view",
          "readOnly": true
        },
        "slotId": {
          "type": "string",
          "description": "Unique Id of the slot containing this embedded view.",
          "readOnly": true
        },
        "isVisible": {
          "type": "boolean",
          "description": "Whether this embedded view is visible or not.",
          "readOnly": true
        }
      }
    }
  ]
}
